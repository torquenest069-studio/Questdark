.hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding-top: var(--space-32);
    overflow: hidden;
}

.layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-20);
    align-items: center;
}

.trustPill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(0, 245, 255, 0.1);
    color: var(--accent-cyan);
    padding: var(--space-2) var(--space-4);
    border-radius: 50px;
    font-size: var(--font-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-6);
    border: 1px solid rgba(0, 245, 255, 0.2);
}

.pulse {
    width: 8px;
    height: 8px;
    background: var(--accent-cyan);
    border-radius: 50%;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(0, 245, 255, 0.7);
    }

    70% {
        transform: scale(1);
        box-shadow: 0 0 0 10px rgba(0, 245, 255, 0);
    }

    100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(0, 245, 255, 0);
    }
}

.title {
    font-size: var(--font-4xl);
    margin-bottom: var(--space-8);
    max-width: 700px;
}

.description {
    font-size: var(--font-lg);
    color: var(--text-muted);
    margin-bottom: var(--space-10);
    max-width: 580px;
    line-height: 1.6;
}

.actions {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
}

.btnPrimary {
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-blue));
    color: var(--primary-bg);
    padding: var(--space-4) var(--space-8);
    border-radius: var(--space-2);
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    transition: var(--transition-normal);
}

.btnPrimary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
}

.btnSecondary {
    background: var(--glass-bg);
    color: var(--text-main);
    padding: var(--space-4) var(--space-8);
    border-radius: var(--space-2);
    font-weight: 700;
    border: 1px solid var(--glass-border);
    transition: var(--transition-normal);
}

.btnSecondary:hover {
    background: var(--glass-border);
    border-color: var(--text-muted);
}

.metrics {
    display: flex;
    gap: var(--space-12);
}

.metric {
    display: flex;
    flex-direction: column;
}

.metricVal {
    font-size: var(--font-2xl);
    font-weight: 800;
    color: var(--accent-cyan);
}

.metricLabel {
    font-size: var(--font-xs);
    color: var(--text-dim);
    text-transform: uppercase;
    font-weight: 600;
}

.visual {
    position: relative;
}

.card {
    padding: var(--space-10);
    border-radius: var(--space-6);
    z-index: 2;
    position: relative;
}

.cardHeader {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
}

.cardHeader h3 {
    font-size: var(--font-xl);
}

.icon {
    color: var(--accent-cyan);
}

.features {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
}

.feature {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-muted);
    font-size: var(--font-base);
}

.fIcon {
    color: var(--accent-cyan);
}

.cardFooter {
    border-top: 1px solid var(--glass-border);
    padding-top: var(--space-6);
}

.status {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-xs);
    font-weight: 700;
    color: var(--accent-cyan);
    margin-bottom: var(--space-2);
}

.dot {
    width: 6px;
    height: 6px;
    background: var(--accent-cyan);
    border-radius: 50%;
}

.indicator {
    height: 4px;
    background: var(--glass-border);
    border-radius: 2px;
    overflow: hidden;
}

.bar {
    height: 100%;
    width: 65%;
    background: var(--accent-cyan);
    border-radius: 2px;
}

.glow1 {
    position: absolute;
    top: -20%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 245, 255, 0.1), transparent 70%);
    z-index: 1;
}

.glow2 {
    position: absolute;
    bottom: -20%;
    left: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.1), transparent 70%);
    z-index: 1;
}

@media (max-width: 1200px) {
    .title {
        font-size: var(--font-3xl);
    }
}

@media (max-width: 1024px) {
    .layout {
        grid-template-columns: 1fr;
        text-align: center;
        gap: var(--space-16);
    }
}

@media (max-width: 640px) {
    .title {
        font-size: var(--font-2xl);
    }

    .actions {
        flex-direction: column;
    }

    .metrics {
        gap: var(--space-6);
    }
}